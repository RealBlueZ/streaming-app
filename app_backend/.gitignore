# Dependency directories (never commit this)
node_modules/

# Environment variables (contains local secrets, API keys, database passwords)
.env
.env.local

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Diagnostic reports
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Production build outputs (if using TypeScript or bundlers)
dist/
build/

# Operating system files
.DS_Store
Thumbs.db